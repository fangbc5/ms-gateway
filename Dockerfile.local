# 简化版 Dockerfile - 使用本地构建的二进制文件
# 使用方法：
# 1. 本地构建：cargo build --release
# 2. 构建镜像：docker build -f Dockerfile.local -t ms-gateway .

FROM gcr.io/distroless/cc-debian12

# 从本地复制已编译的二进制文件
COPY target/release/ms-gateway /usr/local/bin/ms-gateway

# 复制配置文件
COPY routes.toml /app/routes.toml

# 设置工作目录
WORKDIR /app

# 暴露端口
EXPOSE 8080

# 设置环境变量
ENV RUST_LOG=info
ENV GATEWAY_BIND=0.0.0.0:8080

# 运行应用
ENTRYPOINT ["/usr/local/bin/ms-gateway"]
